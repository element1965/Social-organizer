# Railway environment variables
DATABASE_URL="postgresql://postgres:1111@localhost:5434/social_organizer?schema=public"
PORT=3001
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production
ADMIN_IDS=

# Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@orginizer.com

# Google OAuth (verify tokens server-side)
GOOGLE_CLIENT_ID=

# Sign in with Apple (web OAuth, verify id_token server-side)
# APPLE_SERVICE_ID = the Services ID created in Apple Developer (e.g. com.socialorganizer.signin)
APPLE_SERVICE_ID=
# Native app bundle id, accepted as a fallback audience (default: com.socialorganizer.app)
APPLE_BUNDLE_ID=com.socialorganizer.app
# Paste the contents of Apple's domain-association file (served at
# /.well-known/apple-developer-domain-association.txt for Services ID domain verification)
APPLE_DOMAIN_ASSOCIATION=

# Web frontend build-time (apps/web/.env)
# VITE_GOOGLE_CLIENT_ID=
# VITE_APPLE_SERVICE_ID=  (same Services ID as APPLE_SERVICE_ID)
